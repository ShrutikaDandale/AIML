   "source": [
    "# normalization\n",
    "arr = np.array([[1, 2], [3, 4]])\n",
    "\n",
    "mean = np.mean(arr) #to calculate the mean of the array\n",
    "std_dev = np.std(arr)\n",
    "\n",
    "print(mean)\n",
    "print(std_dev)\n",
    "\n",
    "normalized_arr = (arr-mean)/std_dev\n",
    "print(normalized_arr)"
   ]
